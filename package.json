{
  "name": "novawear",
  "private": true,
  "scripts": {
    "dev": "pnpm --stream -r --parallel --filter coolmate-be --filter coolmate-fe run dev",
    "dev:web": "pnpm --filter coolmate-fe dev",
    "dev:api": "pnpm --filter coolmate-be dev",
    "build": "pnpm --filter coolmate-be build && pnpm --filter coolmate-fe build",
    "build:api": "pnpm --filter coolmate-be build",
    "build:web": "pnpm --filter coolmate-fe build",
    "start": "pnpm --filter coolmate-be start",
    "lint": "pnpm --filter coolmate-be lint && pnpm --filter coolmate-fe lint"
  }
}
